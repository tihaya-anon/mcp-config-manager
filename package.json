{
  "name": "mcp-config-manager-extension",
  "displayName": "MCP Config Manager",
  "description": "Manage MCP servers and export config for Claude Code/Codex.",
  "version": "0.2.0",
  "publisher": "your-publisher",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcpConfigManager",
          "title": "MCP",
          "icon": "$(plug)"
        }
      ]
    },
    "views": {
      "mcpConfigManager": [
        {
          "id": "mcpConfigManager.servers",
          "name": "Servers",
          "icon": "$(server)"
        },
        {
          "id": "mcpConfigManager.tools",
          "name": "Tools",
          "icon": "$(tools)"
        }
      ]
    },
    "commands": [
      {
        "command": "mcpConfigManager.openStudio",
        "title": "MCP: Open Studio",
        "icon": "$(layout)"
      },
      {
        "command": "mcpConfigManager.addMcp",
        "title": "MCP: Add Server",
        "icon": "$(add)"
      },
      {
        "command": "mcpConfigManager.editMcp",
        "title": "MCP: Edit Server",
        "icon": "$(edit)"
      },
      {
        "command": "mcpConfigManager.toggleMcp",
        "title": "MCP: Toggle Server",
        "icon": "$(run)"
      },
      {
        "command": "mcpConfigManager.toggleMcpOn",
        "title": "MCP: Enable Server",
        "icon": "$(debug-start)"
      },
      {
        "command": "mcpConfigManager.toggleMcpOff",
        "title": "MCP: Disable Server",
        "icon": "$(debug-stop)"
      },
      {
        "command": "mcpConfigManager.removeMcp",
        "title": "MCP: Remove Server",
        "icon": "$(trash)"
      },
      {
        "command": "mcpConfigManager.exportClaudeCode",
        "title": "MCP: Export for Claude Code",
        "icon": "$(export)"
      },
      {
        "command": "mcpConfigManager.exportCodex",
        "title": "MCP: Export for Codex",
        "icon": "$(export)"
      },
      {
        "command": "mcpConfigManager.previewTemplate",
        "title": "MCP: Preview Template",
        "icon": "$(eye)"
      },
      {
        "command": "mcpConfigManager.toggleExportPathMode",
        "title": "MCP: Toggle Export Path Mode",
        "icon": "$(settings-gear)"
      },
      {
        "command": "mcpConfigManager.toggleDefinitionStorageScope",
        "title": "MCP: Toggle Definition Storage Scope",
        "icon": "$(database)"
      },
      {
        "command": "mcpConfigManager.refreshServers",
        "title": "MCP: Refresh Servers",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "mcpConfigManager.toggleMcpOn",
          "when": "view == mcpConfigManager.servers && viewItem == mcpServerDisabled",
          "group": "inline@1"
        },
        {
          "command": "mcpConfigManager.toggleMcpOff",
          "when": "view == mcpConfigManager.servers && viewItem == mcpServerEnabled",
          "group": "inline@1"
        },
        {
          "command": "mcpConfigManager.editMcp",
          "when": "view == mcpConfigManager.servers",
          "group": "inline@2"
        },
        {
          "command": "mcpConfigManager.removeMcp",
          "when": "view == mcpConfigManager.servers",
          "group": "inline@3"
        }
      ]
    },
    "configuration": {
      "title": "MCP Config Manager",
      "properties": {
        "mcpConfigManager.export.claudeCodeTemplate": {
          "type": "string",
          "default": "{\n  \"mcpServers\": {{json servers_resolved_by_name}}\n}",
          "scope": "resource",
          "markdownDescription": "Template for Claude Code export. Supports variables, each/if blocks, and helpers: json, toml, tomlKey. Use servers_resolved_by_name for Claude-compatible output; full McpServer fields are in servers / servers_by_name."
        },
        "mcpConfigManager.export.codexTemplate": {
          "type": "string",
          "default": "# Codex MCP config\n{{#each servers}}[mcp_servers.{{tomlKey name}}]\n{{#if resolved.url}}url = {{toml resolved.url}}\n{{/if}}{{#if resolved.headers}}http_headers = {{toml resolved.headers}}\n{{/if}}{{#if resolved.command}}command = {{toml resolved.command}}\n{{/if}}{{#if resolved.args}}args = {{toml resolved.args}}\n{{/if}}{{#if resolved.env}}env = {{toml resolved.env}}\n{{/if}}\n{{/each}}",
          "scope": "resource",
          "markdownDescription": "Template for Codex export. Supports variables, each/if blocks, and helpers: json, toml, tomlKey. Use resolved fields for Codex-compatible output; full McpServer fields are in servers / servers_by_name."
        },
        "mcpConfigManager.export.writeToWorkspace": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "markdownDescription": "When true, export writes directly to workspace files (`.mcp.json` for Claude Code, `.codex/config.toml` for Codex)."
        },
        "mcpConfigManager.servers": {
          "type": "array",
          "default": [],
          "scope": "resource",
          "markdownDescription": "Workspace-tracked MCP server definitions (without runtime enabled/disabled state)."
        },
        "mcpConfigManager.definitionStorageScope": {
          "type": "string",
          "enum": [
            "workspace",
            "user"
          ],
          "default": "workspace",
          "scope": "application",
          "markdownDescription": "Where MCP server definitions are stored: workspace settings or user settings."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/vscode": "^1.90.0",
    "eslint": "^9.4.0",
    "typescript": "^5.4.5"
  }
}
